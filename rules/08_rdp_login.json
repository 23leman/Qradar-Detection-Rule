{
  "name": "RDP Remote Login Detected",
  "note": "Detects remote desktop login - T1021.001",
  "type": "EVENT",
  "enabled": true,
  "responses": [{"type": "OFFENSE", "descriptor": "RDP Remote Login Detected"}],
  "groups": ["Lateral Movement"],
  "aql_filter": "SELECT * FROM events WHERE EventID = '4624' AND payload ILIKE '%Logon Type: 10%'",
  "tests": [
    {"uid": 1, "name": "EventID", "operator": "EQUALS", "value": "4624"},
    {"uid": 2, "name": "Payload", "operator": "CONTAINS", "value": "Logon Type: 10"}
  ]
}
